#!/usr/bin/env python3
"""Compute apply waves = topological levels of the Terramate `after` DAG.

Reads `terramate experimental run-graph` dot output on stdin and a work-set of
{stack, environment, workload} cells from SHIPMATE_WORKSET (JSON). Emits
wave0..wave7 cell arrays. Ordering is over the FULL graph, then filtered to the
work set, so transitive order through unchanged stacks is preserved and empty
middle waves are normal.
"""

import json
import os
import re
import sys
from graphlib import CycleError, TopologicalSorter

MAX_WAVES = 8
_NODE = re.compile(r'(\w+)\s*\[label="([^"]+)"\]')
_EDGE = re.compile(r"^\s*(\w+)\s*->\s*(\w+)")


def parse_dot(text):
    """Return {stack_path: set(paths-that-run-before-it)} from run-graph dot.

    Generated with `terramate experimental run-graph --label stack.dir`: node
    ids (nN) carry `label="/stacks/app"` (absolute-from-root dir). Normalize to
    `list` form (`stacks/app`) by stripping the leading '/'. An edge `nA -> nB`
    means A runs before B, so B depends on A. Isolated nodes (no edges) are
    included with an empty dependency set.
    """
    ids = {nid: label.lstrip("/") for nid, label in _NODE.findall(text)}
    deps = {path: set() for path in ids.values()}
    for line in text.splitlines():
        if "[label=" in line:  # node declaration, not an edge
            continue
        m = _EDGE.match(line)
        if not m:
            continue
        before, after = ids.get(m.group(1)), ids.get(m.group(2))
        if before is not None and after is not None:
            deps[after].add(before)
    return deps


def levels(deps):
    """Topological levels; level 0 = nodes with no dependencies."""
    ts = TopologicalSorter(deps)
    ts.prepare()
    out = []
    while ts.is_active():
        ready = sorted(ts.get_ready())
        out.append(ready)
        for n in ready:
            ts.done(n)
    return out


def assign_waves(levels_, cells):
    """Bucket cells by the full-graph level of their stack (index-preserving)."""
    level_of = {stack: i for i, lv in enumerate(levels_) for stack in lv}
    if not levels_:
        if cells:
            # Fail loud: an empty graph with pending cells means run-graph failed
            # or returned nothing — never silently skip applies that are due.
            raise SystemExit(
                "::error::run-graph produced no levels but the work set is non-empty; "
                "refusing to silently drop pending applies (empty or failed run-graph?)."
            )
        return []
    waves = [[] for _ in range(len(levels_))]
    for c in cells:
        if c["stack"] not in level_of:
            raise SystemExit(
                f"::error::stack '{c['stack']}' is not a node in the run-graph; "
                "cannot order it into a wave (regenerate run-graph or check the label)."
            )
        waves[level_of[c["stack"]]].append(c)
    return waves


def guard_max_waves(waves):
    """Fail if a populated wave lands beyond the pre-declared wave0..wave7 jobs.
    A deep FULL graph with only low-level cells in the work set is fine — empty
    trailing levels do not count."""
    over = [i for i, w in enumerate(waves) if w and i >= MAX_WAVES]
    if over:
        raise SystemExit(
            f"::error::change spans {over[-1] + 1} dependency levels (> {MAX_WAVES}); split the PR."
        )


def write_waves(fh, waves):
    """Emit wave0..wave{MAX_WAVES-1} (JSON arrays) + the `empty` flag to a
    GITHUB_OUTPUT file handle. Shared by this script and deploy-detect."""
    for i in range(MAX_WAVES):
        fh.write(f"wave{i}={json.dumps(waves[i] if i < len(waves) else [])}\n")
    fh.write(f"empty={'false' if any(waves) else 'true'}\n")


def main(argv):
    deps = parse_dot(sys.stdin.read())
    try:
        lv = levels(deps)
    except CycleError as e:
        raise SystemExit(f"::error::dependency cycle in run-graph: {e}") from e
    waves = assign_waves(lv, json.loads(os.environ.get("SHIPMATE_WORKSET", "[]")))
    if "--reverse" in argv:
        waves = list(reversed(waves))
    # Guard AFTER reversing: --reverse can move a populated low level past index 7,
    # where write_waves would silently drop it.
    guard_max_waves(waves)
    with open(os.environ["GITHUB_OUTPUT"], "a", encoding="utf-8") as fh:
        write_waves(fh, waves)


if __name__ == "__main__":
    main(sys.argv)
