#!/usr/bin/env python3
"""deploy.yml detect: merge commit -> PR head SHA -> pending applies -> waves.

Exact-plan / fail-safe model: the work set is the merged PR's changed stacks
whose apply check is still pending (completed = applied pre-merge, or
no-change). No 'last deployed ref' diff — pending checks ARE the queue.
"""

import importlib.util
import os
import pathlib
import time
from graphlib import CycleError
from importlib.machinery import SourceFileLoader

_D = pathlib.Path(__file__).resolve().parent


def _load(fname):
    loader = SourceFileLoader(fname.replace("-", "_"), str(_D / fname))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    mod = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    return mod


bm = _load("build-matrix")
wv = _load("waves")
eo = _load("env-order")
ag = _load("apply-gate")


def filter_pending(cells, completed_names):
    return [c for c in cells if f"apply / {c['environment']} / {c['stack']}" not in completed_names]


# Single-sourced in build-matrix (next to _run); aliased here so error handling
# (nonzero exit -> ::error::) has one definition and tests can monkeypatch it.
_gh_json = bm.gh_json


def _merged_head(repo, merge_sha, _attempts=3, _sleep=2):
    """Map a merge commit -> the head SHA of the PR it merged.

    Reviewed .otplan artifacts and apply checks live on the PR head, not on main.
    Edge cases handled: (1) `commits/{sha}/pulls` can transiently return [] for a
    few seconds after the push (association indexing lag) — retry before falling
    back; (2) a commit may be associated with more than one PR — pick the one
    this commit actually merged (merge_commit_sha == merge_sha); (3) if none of
    the returned pulls match exactly, only *merged* PRs (`merged_at` set) are
    eligible fallback candidates — an OPEN PR that merely contains the pushed
    commit must never be selected, since deploying its plans would apply more
    than main actually contains. If no pull qualifies, head = merge_sha, same as
    a genuine non-PR push to main.
    """
    for attempt in range(_attempts):
        pulls = _gh_json(f"repos/{repo}/commits/{merge_sha}/pulls")
        if pulls:
            exact = next((p for p in pulls if p.get("merge_commit_sha") == merge_sha), None)
            if exact is not None:
                return exact["head"]["sha"]
            merged = next((p for p in pulls if p.get("merged_at")), None)
            return merged["head"]["sha"] if merged is not None else merge_sha
        if attempt < _attempts - 1:
            time.sleep(_sleep)
    return merge_sha


def main():
    repo = os.environ["GITHUB_REPOSITORY"]
    merge_sha = os.environ["GITHUB_SHA"]
    head = _merged_head(repo, merge_sha)
    cells = bm.compute_cells(all_stacks=False, base=os.environ.get("SHIPMATE_BASE_SHA", ""))
    # Check-runs are paginated (a 256-cell PR yields >100); --paginate --jq streams
    # them as JSONL so no page — hence no completed apply — is silently dropped.
    checks_jsonl = bm._run(
        [
            "gh",
            "api",
            "--paginate",
            "--jq",
            ".check_runs[]",
            f"repos/{repo}/commits/{head}/check-runs?filter=all&per_page=100",
        ]
    )
    # Only App-authored apply checks count: a forged same-name check from any
    # other identity must not mark work done (see apply-gate.from_app).
    checks = ag.from_app(ag.parse_jsonl(checks_jsonl.splitlines()), os.environ["SHIPMATE_APP_ID"])
    # Shared with apply-gate: a name is done only if its *latest* run is
    # completed with a good conclusion — not merely "some run of this name
    # ever completed" (which would wedge on a failed/superseded run).
    completed = ag.done_names(checks)
    pending = filter_pending(cells, completed)
    graph = bm._run(["terramate", "experimental", "run-graph", "--label", "stack.dir"])
    deps = wv.parse_dot(graph)
    order = eo.read_env_order()
    levels = eo.env_levels(order, {c["environment"] for c in pending})
    eo.guard_max_env_levels(levels)
    per_level = eo.waves_by_env_level(pending, deps, levels)
    runs = _gh_json(
        f"repos/{repo}/actions/workflows/plan.yml/runs?head_sha={head}&status=success"
    ).get("workflow_runs", [])
    plan_run = runs[0]["id"] if runs else ""
    level_counts = [sum(len(waves[f"wave{i}"]) for i in range(wv.MAX_WAVES)) for waves in per_level]
    print(
        f"::notice title=deploy-detect::base={os.environ.get('SHIPMATE_BASE_SHA', '')} "
        f"head={head} cells={len(cells)} completed={len(completed)} pending={len(pending)} "
        f"envlevels={level_counts} plan_run={plan_run} empty={not any(level_counts)}"
    )
    # Output names must be hyphen-free: `steps.d.outputs.head-sha` parses the '-'
    # as subtraction, breaking the composite action's outputs block. Underscores.
    with open(os.environ["GITHUB_OUTPUT"], "a", encoding="utf-8") as fh:
        eo.write_env_level_waves(fh, per_level)
        fh.write(f"head_sha={head}\n")
        fh.write(f"plan_run_id={plan_run}\n")


if __name__ == "__main__":
    try:
        main()
    except bm.MatrixTooLarge as e:
        raise SystemExit(f"::error::{e}") from e
    except CycleError as e:
        raise SystemExit(f"::error::dependency cycle in run-graph or env-order: {e}") from e
