#!/usr/bin/env python3
"""apply.yml detect: a dispatched single-env apply's work set + waves.

Unlike deploy-detect (merge-driven, all envs), the work set here is scoped to
ONE environment and sourced from a specific preview run's plan artifacts:
`plan.<env>.<slug>` artifacts present in SHIPMATE_PLAN_RUN_ID name exactly the
stacks that were planned for this env. We map each present slug back to a stack
PATH via the run-graph (path->slug is one-way; we slug each graph node forward
and match), drop cells whose apply check already completed (idempotent no-op),
then wave-order. A targeted `mate apply <env>` is single-env and explicit by
design — it never blocks on other environments; region-level sequencing across
envs is handled separately on the apply-all path.
"""

import importlib.util
import os
import pathlib
import re
from graphlib import CycleError
from importlib.machinery import SourceFileLoader

_D = pathlib.Path(__file__).resolve().parent

_SHA_RE = re.compile(r"^[0-9a-f]{40}$")
_RUN_ID_RE = re.compile(r"^[0-9]+$")


def _load(fname):
    loader = SourceFileLoader(fname.replace("-", "_"), str(_D / fname))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    mod = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    return mod


bm = _load("build-matrix")
wv = _load("waves")
ag = _load("apply-gate")


def _slug(path):
    return path.replace("/", "-")


def workset_from_artifacts(artifact_names, env, graph_paths):
    """Cells for `env` = graph stacks whose exact `plan.<env>.<slug>` artifact is
    present in the plan run. Forward-construct the expected name per graph path
    (never reverse-parse the artifact name). The `.` delimiter is unambiguous
    because a Terramate env name cannot contain `.` (tag grammar forbids it), so
    with env first the first `.` after the `plan.` prefix is always the env<->slug
    boundary -- distinct (env, slug) pairs always render distinct names, unlike
    the old `plan-<slug>-<env>` where a dash-bearing env (e.g. `eu`) could
    cross-match another env's artifacts (`...-dev-eu`). path->slug is
    many-to-one, so fail loud if two paths collide."""
    names = set(artifact_names)
    cells = [
        {"stack": p, "environment": env} for p in graph_paths if f"plan.{env}.{_slug(p)}" in names
    ]
    slugs = [_slug(c["stack"]) for c in cells]
    dupes = sorted({s for s in slugs if slugs.count(s) > 1})
    if dupes:
        raise SystemExit(
            f"::error::stack path slug collision {dupes}: distinct stack paths map "
            "to the same artifact slug; rename so the path->'-' slug is unique."
        )
    return cells


def filter_pending(cells, completed_names):
    return [c for c in cells if f"apply / {c['environment']} / {c['stack']}" not in completed_names]


# Single-sourced in build-matrix (next to _run); aliased here so error handling
# (nonzero exit -> ::error::) has one definition and tests can monkeypatch it.
_gh_json = bm.gh_json


def verify_plan_run(repo, run_id, head_sha):
    """Provenance gate for a dispatched apply: comment-ops' `authorize` already
    binds head<->run on the comment path, but a direct `workflow_dispatch` (or a
    hand-edited one) skips that binding entirely. This check is therefore the
    trust boundary for dispatched applies -- without it, a mismatched
    run/head pair would apply another run's reviewed plans and green-tick the
    wrong PR's checks."""
    run = _gh_json(f"repos/{repo}/actions/runs/{run_id}")
    if run.get("head_sha") != head_sha:
        raise SystemExit(
            f"::error::plan run {run_id} head_sha mismatch: expected {head_sha}, "
            f"got {run.get('head_sha')}"
        )
    if run.get("conclusion") != "success":
        raise SystemExit(
            f"::error::plan run {run_id} conclusion is {run.get('conclusion')!r}, "
            "expected 'success'"
        )
    path = run.get("path") or ""
    if not path.endswith("/preview.yml"):
        raise SystemExit(
            f"::error::plan run {run_id} is not a preview.yml run: workflow path is {path!r}"
        )


def _artifact_names(repo, run_id):
    data = bm._run(
        [
            "gh",
            "api",
            "--paginate",
            "--jq",
            ".artifacts[].name",
            f"repos/{repo}/actions/runs/{run_id}/artifacts?per_page=100",
        ]
    )
    return [ln.strip() for ln in data.splitlines() if ln.strip()]


def validate_head_sha(value):
    """Guard against a malformed SHIPMATE_HEAD_SHA retargeting the gh api URLs
    built from it (e.g. `/`, `?`, `..`). Safe to echo — not a secret."""
    if not _SHA_RE.fullmatch(value):
        raise SystemExit(
            f"::error::SHIPMATE_HEAD_SHA must be a 40-char lowercase hex SHA (got: {value!r})"
        )


def validate_plan_run_id(value):
    """Guard against a malformed SHIPMATE_PLAN_RUN_ID retargeting the gh api URLs
    built from it. Safe to echo — not a secret."""
    if not _RUN_ID_RE.fullmatch(value):
        raise SystemExit(f"::error::SHIPMATE_PLAN_RUN_ID must be a numeric run id (got: {value!r})")


def main():
    repo = os.environ["GITHUB_REPOSITORY"]
    env = os.environ["SHIPMATE_ENV"]
    plan_run_id = os.environ["SHIPMATE_PLAN_RUN_ID"]
    head = os.environ["SHIPMATE_HEAD_SHA"]

    validate_head_sha(head)
    validate_plan_run_id(plan_run_id)

    verify_plan_run(repo, plan_run_id, head)

    graph = bm._run(["terramate", "experimental", "run-graph", "--label", "stack.dir"])
    deps = wv.parse_dot(graph)
    graph_paths = list(deps.keys())

    names = _artifact_names(repo, plan_run_id)
    cells = workset_from_artifacts(names, env, graph_paths)

    checks_jsonl = bm._run(
        [
            "gh",
            "api",
            "--paginate",
            "--jq",
            ".check_runs[]",
            f"repos/{repo}/commits/{head}/check-runs?filter=all&per_page=100",
        ]
    )
    checks = ag.parse_jsonl(checks_jsonl.splitlines())
    # Shared with apply-gate: a name is done only if its *latest* run is
    # completed with a good conclusion — not merely "some run of this name
    # ever completed" (which would wedge on a failed/superseded run).
    completed = ag.done_names(checks)
    pending = filter_pending(cells, completed)

    waves = wv.assign_waves(wv.levels(deps), pending)
    wv.guard_max_waves(waves)
    print(
        f"::notice title=apply-detect::env={env} plan_run={plan_run_id} head={head} "
        f"cells={len(cells)} completed={len(completed)} pending={len(pending)} "
        f"waves={[len(w) for w in waves]} empty={not any(waves)}"
    )
    with open(os.environ["GITHUB_OUTPUT"], "a", encoding="utf-8") as fh:
        wv.write_waves(fh, waves)
        fh.write(f"head_sha={head}\n")
        fh.write(f"preview_run_id={plan_run_id}\n")


if __name__ == "__main__":
    try:
        main()
    except CycleError as e:
        raise SystemExit(f"::error::dependency cycle in run-graph: {e}") from e
