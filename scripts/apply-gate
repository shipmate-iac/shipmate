#!/usr/bin/env python3
"""Decide whether every `apply / <env> / <stack>` check on a commit is done.

Reads check-runs as JSON Lines on stdin (one check-run object per line, as
emitted by `gh api --paginate ... --jq '.check_runs[]'`) and writes a single
verdict to GITHUB_OUTPUT:

- `complete`   — every apply check's latest run is completed with a good
                 conclusion (success, or neutral for no-change cells); the
                 caller may complete the `shipmate / gate` check.
- `pending`    — at least one apply check is still open, failed, or was
                 cancelled; the caller must leave the gate untouched.
- `no-applies` — the commit has no apply checks at all (nothing to gate on);
                 the caller must leave the gate untouched.

Check-runs are filtered to the shipmate GitHub App's identity (`from_app`,
env `SHIPMATE_APP_ID`) before verdict is computed, so a same-name run created
by any other identity can never feed the gate.

The GitHub API returns every historical run of a re-created check name, so
runs are grouped by name and judged by the newest run per name, ordered by
check-run id (monotonically increasing with creation, and always present --
unlike a queued run's nullable started_at, which could otherwise sort a newer
queued duplicate below an older completed run).
"""

import json
import os
import sys

APPLY_PREFIX = "apply / "
DONE_CONCLUSIONS = {"success", "neutral"}


def latest_by_name(check_runs, prefix=APPLY_PREFIX):
    """Group check-runs by name (names starting with `prefix`; default: apply
    checks), keeping only the newest run per name. "Newest" is by check-run
    `id`: GitHub assigns ids monotonically at creation, so the highest id is
    the most recently created run -- and unlike `started_at` (nullable; a
    freshly-created queued run may carry none) it is always present, so a
    newer queued duplicate never sorts below an older completed run.
    summary-comment reuses this with prefix="" (it resolves plan-check links by
    an exact `<stack> / <env>` lookup, not a prefix filter). Returns {name: run}."""
    latest = {}
    for run in check_runs:
        name = run["name"]
        if not name.startswith(prefix):
            continue
        key = run.get("id") or 0
        if name not in latest or key > latest[name][0]:
            latest[name] = (key, run)
    return {name: run for name, (_, run) in latest.items()}


def _is_done(run):
    return run["status"] == "completed" and run.get("conclusion") in DONE_CONCLUSIONS


def done_names(check_runs):
    """Names whose *latest* run is completed with a good conclusion (success,
    or neutral for no-change cells). This is the single done-predicate shared
    with deploy-detect / apply-detect so a "completed" status with a bad
    conclusion, or a stale completed run superseded by a newer pending one,
    is never mistaken for done."""
    return {name for name, run in latest_by_name(check_runs).items() if _is_done(run)}


def parse_jsonl(lines):
    """Parse newline-delimited JSON (one object per line, blank lines
    skipped), as emitted by `gh api --paginate --jq`. A malformed line raises
    SystemExit naming the offending line (truncated) instead of letting a raw
    json.JSONDecodeError traceback obscure which line was bad. Shared by this
    script's stdin parsing and by deploy-detect / apply-detect's check-runs
    parsing."""
    out = []
    for line in lines:
        line = line.strip()
        if not line:
            continue
        try:
            out.append(json.loads(line))
        except json.JSONDecodeError as e:
            raise SystemExit(f"::error::malformed JSON line ({e}): {line[:120]!r}") from e
    return out


def from_app(check_runs, app_id):
    """Keep only check-runs created by the given GitHub App id.

    Check-run writes moved to the shipmate App: a same-name check created by
    any other identity (github-actions app id 15368, another App) must never
    feed a gate verdict or a detect work queue — a forged newer completed
    duplicate would otherwise green a pending name via latest_by_name, and a
    forged pending one would wedge the gate. Runs with no `app` field are
    dropped too (fail-closed)."""
    want = int(app_id)
    return [r for r in check_runs if ((r.get("app") or {}).get("id")) == want]


def app_done_names(check_run_lines, app_id):
    """done_names restricted to a single App's apply checks: parse JSONL,
    from_app-filter to app_id, then done_names. The one entry point the
    detects call, so "only App-authored checks count as done" lives in one
    place — dropping the from_app filter here is a visible, tested change."""
    return done_names(from_app(parse_jsonl(check_run_lines), app_id))


def verdict(check_runs):
    latest = latest_by_name(check_runs)
    if not latest:
        return "no-applies"
    if all(_is_done(run) for run in latest.values()):
        return "complete"
    return "pending"


def main():
    runs = from_app(parse_jsonl(sys.stdin), os.environ["SHIPMATE_APP_ID"])
    v = verdict(runs)
    with open(os.environ["GITHUB_OUTPUT"], "a", encoding="utf-8") as fh:
        fh.write(f"verdict={v}\n")


if __name__ == "__main__":
    main()
