#!/usr/bin/env python3
"""Compute the preview plan matrix: changed stacks x their env tags -> cells.

Pure core (build_matrix) is unit-tested; main() gathers inputs from terramate
+ the GitHub Environments API and writes GitHub Actions job outputs.
"""
import json
import os
import subprocess
import sys

MATRIX_LIMIT = 256


class MatrixTooLarge(Exception):
    pass


def build_matrix(envs, stacks_by_env, tags_by_stack):
    cells = []
    for env in envs:
        for stack in stacks_by_env.get(env, []):
            workload = ""
            for tag in tags_by_stack.get(stack, []):
                if tag.startswith("workload/"):
                    workload = tag[len("workload/"):]
                    break
            cells.append({"stack": stack, "environment": env, "workload": workload})
    cells.sort(key=lambda c: (c["environment"], c["stack"]))
    if len(cells) > MATRIX_LIMIT:
        raise MatrixTooLarge(
            f"{len(cells)} plan cells exceeds the GitHub Actions matrix limit of {MATRIX_LIMIT}. "
            "Split the change across multiple PRs."
        )
    return cells


def _run(args):
    return subprocess.run(args, capture_output=True, text=True, check=True).stdout


def _plan_envs():
    repo = os.environ["GITHUB_REPOSITORY"]
    out = _run(["gh", "api", f"repos/{repo}/environments", "--paginate",
                "--jq", ".environments[].name"])
    names = [n.strip() for n in out.splitlines() if n.strip()]
    # Drop the apply half of the plan/apply split; dedupe; stable order.
    plan = sorted({n for n in names if not n.endswith("-apply")})
    return plan


def _changed_stacks(env, base):
    args = ["terramate", "list", "--changed", "--tags", f"env/{env}"]
    if base:
        args += ["-B", base]
    return [s.strip() for s in _run(args).splitlines() if s.strip()]


def _tags(stack):
    out = _run(["terramate", "-C", stack, "experimental", "eval", "terramate.stack.tags"])
    return json.loads(out)


def main():
    base = os.environ.get("SHIPMATE_BASE_SHA", "")
    envs = _plan_envs()
    stacks_by_env = {e: _changed_stacks(e, base) for e in envs}
    all_stacks = {s for lst in stacks_by_env.values() for s in lst}
    tags_by_stack = {s: _tags(s) for s in all_stacks}
    cells = build_matrix(envs, stacks_by_env, tags_by_stack)
    out_path = os.environ["GITHUB_OUTPUT"]
    with open(out_path, "a", encoding="utf-8") as fh:
        fh.write(f"matrix={json.dumps({'include': cells})}\n")
        fh.write(f"empty={'true' if not cells else 'false'}\n")
        fh.write(f"count={len(cells)}\n")
    listing = ", ".join(f"{c['environment']}/{c['stack']}" for c in cells) or "(none)"
    print(f"{len(cells)} plan cell(s) across {len(envs)} env(s): {listing}")


if __name__ == "__main__":
    try:
        main()
    except MatrixTooLarge as e:
        print(f"::error::{e}", file=sys.stderr)
        sys.exit(1)
