#!/usr/bin/env python3
"""Build the sticky preview comment: overview table + per-cell plan details.

Reads `plan / <env> / <stack>` check-runs as JSON Lines on stdin (as emitted
by `gh api --paginate ... --jq '.check_runs[]'`), cell summaries + rendered
plan text from the $CELLS directory (cell-summary-* artifacts), and writes
comment.md plus pending/count to GITHUB_OUTPUT.

GitHub rejects issue-comment bodies over 65,536 characters. SIZE_BUDGET
leaves headroom below that cap; each changed cell's details section degrades
full plan -> truncated plan -> link-only, never dropping the check-run link.
Plan text is emitted only inside a backtick fence computed to be longer than
any backtick run in the text, so author-controlled plan output cannot escape
the fence (the comment-body injection surface).
"""

import glob
import importlib.util
import json
import os
import pathlib
import re
import sys
from importlib.machinery import SourceFileLoader

_D = pathlib.Path(__file__).resolve().parent


def _load(fname):
    loader = SourceFileLoader(fname.replace("-", "_"), str(_D / fname))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    mod = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    return mod


ag = _load("apply-gate")

MARKER = "<!-- shipmate:summary -->"
PLAN_PREFIX = "plan / "
SIZE_BUDGET = 60_000
HARD_CAP = 65_536
MIN_PLAN_CHARS = 500
CELL_KEYS = ("stack", "stack_path", "environment", "add", "change", "destroy", "changed")

# A plan line's change sign, possibly indented: `+`, `-`, `~`, or the
# replace forms `-/+` / `+/-`. The sign moves to column 0 (GitHub's diff
# highlighting keys on the first character) and `~` becomes `!` (orange).
_SIGN = re.compile(r"^( *)(-/\+|\+/-|[-+~])")

# A heredoc opener (`<<EOT` / `<<-EOT`), capturing the terminator word.
_HEREDOC_OPEN = re.compile(r"<<-?([A-Za-z_][A-Za-z0-9_]*)")


def diff_map(text):
    """Rewrite plan lines so change signs land at column 0 for ```diff
    coloring. The captured indent moves behind the sign, preserving width.

    Heredoc-aware: a heredoc's literal body (e.g. cloud-init YAML embedded in
    a `user_data = <<-EOT` value) can itself start with `-`/`~`/`+` — those
    are content, not plan diff markers. Once an opener line is seen, sign
    mapping is suspended until the line that closes it (its `strip()`, with
    any trailing `,` also stripped, equal to the terminator word), then
    resumes. The opener line itself is still sign-mapped — it is a real
    change line.
    """

    def repl(m):
        sign = "!" if m[2] == "~" else m[2]
        return sign + m[1]

    out = []
    terminator = None
    for line in text.splitlines():
        if terminator is not None:
            out.append(line)
            if line.strip().rstrip(",") == terminator:
                terminator = None
            continue
        out.append(_SIGN.sub(repl, line))
        opener = _HEREDOC_OPEN.search(line)
        if opener:
            terminator = opener[1]
    return "\n".join(out)


def _fence_of(text):
    """A backtick fence strictly longer than any backtick run in `text`
    (min 3) — fence-escape is the only comment-injection vector for content
    rendered inside a code fence."""
    longest = max((len(m) for m in re.findall(r"`+", text)), default=0)
    return "`" * max(3, longest + 1)


def fence(text, f=None):
    f = f or _fence_of(text)
    return f"{f}diff\n{text}\n{f}"


def emoji(cell):
    if not cell["changed"]:
        return "🟢"
    return "🔴" if cell["destroy"] else "🟡"


def _md_escape(s):
    """Neutralize table/summary-line structure characters in author-controlled
    display names (stack-name is a free-form action input). `<`/`>` are
    escaped so a name like `x</summary><b>` cannot close the `<summary>` /
    `<details>` HTML elements the table and section headers are built from.
    `[`/`]` are escaped so a name like `[approve this deploy](https://evil)`
    cannot form a live markdown link inside the trusted bot comment; the
    entities render literally in both the table and `<summary>` contexts."""
    return (
        s.replace("|", "\\|")
        .replace("\r", " ")
        .replace("\n", " ")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace("[", "&#91;")
        .replace("]", "&#93;")
    )


def check_url(cell, checks, run_url):
    """Link target for a cell: the latest `plan / <env> / <stack-path>` check
    run. Name is built FORWARD from the cell's (environment, stack_path) —
    the CONTRACT check-name grammar; never parsed back. Falls back to the
    workflow-run URL when the name is absent (e.g. consumer job renamed)."""
    run = checks.get(f"{PLAN_PREFIX}{cell['environment']} / {cell['stack_path']}")
    return run["html_url"] if run and run.get("html_url") else run_url


def build_table(cells, checks, run_url):
    lines = [
        "| | stack | env | + | ~ | - | check |",
        "|---|---|---|--:|--:|--:|---|",
    ]
    for c in cells:
        lines.append(
            f"| {emoji(c)} | {_md_escape(c['stack'])} | {_md_escape(c['environment'])} "
            f"| {c['add']} | {c['change']} | {c['destroy']} "
            f"| [plan]({check_url(c, checks, run_url)}) |"
        )
    if not cells:
        lines.append("| | _(no stacks changed)_ | | | | | |")
    return "\n".join(lines)


def _summary_line(cell):
    return (
        f"<summary>{emoji(cell)} {_md_escape(cell['environment'])} / "
        f"{_md_escape(cell['stack'])} — "
        f"+{cell['add']} ~{cell['change']} -{cell['destroy']}</summary>"
    )


def link_only(cell, url):
    return (
        f"<details>{_summary_line(cell)}\n\n"
        f"_Plan too large for this comment — [full plan in the check run]({url})._\n"
        f"</details>"
    )


def render_section(cell, plan_text, url, limit):
    """Largest details section that fits in `limit` characters:
    full plan -> truncated plan (cut at a line boundary, check-run link
    appended) -> link-only. The fence for the truncated body reuses the full
    body's fence so a cut can never re-open the fence-escape hole."""
    if plan_text is None:
        return link_only(cell, url)
    body = diff_map(plan_text)
    f = _fence_of(body)
    head = f"<details>{_summary_line(cell)}\n\n"
    full = f"{head}{fence(body, f)}\n</details>"
    # The `limit >= MIN_PLAN_CHARS` guard matters even when `full` already
    # fits: a tiny limit (e.g. the per-cell slice left over in build_comment's
    # extreme-fan-out case) is a signal that this cell's budget is exhausted,
    # not an invitation to inline whatever small plan happens to fit — link
    # the check run instead so every degradation path stays intentional.
    if len(full) <= limit and limit >= MIN_PLAN_CHARS:
        return full
    trailer = f"\n\n_Truncated — [full plan in the check run]({url})._\n</details>"
    room = limit - len(head) - len(fence("", f)) - len(trailer)
    if room >= MIN_PLAN_CHARS:
        sliced = body[:room]
        # Cut at the last full line inside `room`. When the first line alone
        # already exceeds `room`, `rfind` returns -1 and the slice would be
        # the whole (still mid-line) fragment — degrade to link-only instead
        # of violating "cut at a line boundary".
        cut = sliced[: sliced.rfind("\n")] if "\n" in sliced else ""
        if cut:
            return f"{head}{fence(cut, f)}{trailer}"
    return link_only(cell, url)


def build_comment(cells, checks, run_url):
    """Assemble the comment under SIZE_BUDGET. Every changed cell is
    guaranteed at least a link-only section: the space all remaining cells'
    link-only fallbacks need is reserved up front, so an early giant plan
    cannot starve later cells of their links."""
    meta = [c for c, _ in cells]
    header = f"{MARKER}\n### shipmate preview\n\n{build_table(meta, checks, run_url)}"
    footer = f"\n\n[Plans, logs & artifacts]({run_url})"
    changed = [(c, t) for c, t in cells if c["changed"]]
    parts = [header]
    used = len(header) + len(footer)
    # Precompute check_url/link_only once per changed cell (each recomputing
    # it here and again below made every changed cell do the lookup twice).
    enriched = []
    for c, text in changed:
        url = check_url(c, checks, run_url)
        enriched.append((c, text, url, link_only(c, url)))
    reserve = sum(len(lo) + 2 for *_, lo in enriched)
    for c, text, url, lo in enriched:
        reserve -= len(lo) + 2
        section = render_section(c, text, url, SIZE_BUDGET - used - reserve - 2)
        parts.append(section)
        used += len(section) + 2
    body = "\n\n".join(parts) + footer
    if len(body) > HARD_CAP:
        # Extreme fan-out: even link-only sections overflow. The table alone
        # (<=256 rows) normally fits; each row keeps its check-run link.
        fallback = "_Too many changed stacks for inline plans — use each row's check link._"
        body = header + "\n\n" + fallback + footer
        if len(body) > HARD_CAP:
            # Stack/env display names are author-controlled (fork-PR input);
            # at extreme fan-out even the table-only fallback can exceed the
            # hard cap. Fail loud rather than let GitHub's POST 422 on an
            # oversized comment body.
            raise SystemExit(
                "::error::preview table alone exceeds the 65,536-char comment "
                "cap — shorten stack/env display names"
            )
    return body


_STR_KEYS = ("stack", "stack_path", "environment")
_INT_KEYS = ("add", "change", "destroy")


def _validate_cell(cell, path):
    """Type-check cell.json values past the missing-keys check. A
    pin-skewed/crafted cell.json can carry the right keys with the wrong
    types (e.g. `add = "1 |</summary>..."`, or `changed = "false"` — a
    truthy string) and would otherwise land unescaped in the comment and
    wedge the gate. `type(v) is int`, not `isinstance`, because
    `isinstance(True, int)` is `True` and a bool must not pass as an int."""
    for k in _STR_KEYS:
        if type(cell[k]) is not str:
            raise SystemExit(f"::error::cell summary {path} key {k!r} must be a string")
    for k in _INT_KEYS:
        if type(cell[k]) is not int:
            raise SystemExit(f"::error::cell summary {path} key {k!r} must be an int")
    if type(cell["changed"]) is not bool:
        raise SystemExit(f"::error::cell summary {path} key 'changed' must be a bool")


def load_cells(cells_dir):
    """(cell, plan_text) per downloaded cell-summary artifact, sorted by
    (environment, stack). A cell.json missing schema keys, or carrying the
    right keys with the wrong types, fails loud — that is plan-cell/summary
    pin skew, not a state to render around."""
    out = []
    for p in sorted(glob.glob(os.path.join(cells_dir, "**", "cell.json"), recursive=True)):
        with open(p, encoding="utf-8") as fh:
            cell = json.load(fh)
        missing = [k for k in CELL_KEYS if k not in cell]
        if missing:
            raise SystemExit(
                f"::error::cell summary {p} missing keys {missing} — "
                "plan-cell and summary must be pinned at the same engine SHA"
            )
        _validate_cell(cell, p)
        txt = pathlib.Path(p).with_name("plan.txt")
        text = None
        if txt.exists():
            # Cap the read at SIZE_BUDGET: a body of length >= SIZE_BUDGET
            # always exceeds every section's limit (all strictly below
            # SIZE_BUDGET), so characters beyond it could never be emitted
            # anyway — this keeps an unbounded multi-MB plan.txt from being
            # fully read and regex-scanned (diff_map, _fence_of) for nothing.
            with open(txt, encoding="utf-8") as fh:
                text = fh.read(SIZE_BUDGET)
        out.append((cell, text))
    out.sort(key=lambda ct: (ct[0]["environment"], ct[0]["stack"]))
    return out


def main():
    checks = ag.latest_by_name(ag.parse_jsonl(sys.stdin), prefix=PLAN_PREFIX)
    cells = load_cells(os.environ.get("CELLS", "cells"))
    run_url = (
        f"{os.environ['GITHUB_SERVER_URL']}/{os.environ['GITHUB_REPOSITORY']}"
        f"/actions/runs/{os.environ['GITHUB_RUN_ID']}"
    )
    with open("comment.md", "w", encoding="utf-8") as fh:
        fh.write(build_comment(cells, checks, run_url))
    pending = any(c["changed"] for c, _ in cells)
    with open(os.environ["GITHUB_OUTPUT"], "a", encoding="utf-8") as fh:
        fh.write(f"pending={'true' if pending else 'false'}\ncount={len(cells)}\n")


if __name__ == "__main__":
    main()
